# DeadlineOS runs without environment variables in fallback/demo mode.

# Optional: enables server-side Gemini analysis for custom/manual input.
# Demo presets always stay local and fast.
GEMINI_API_KEY=

# Optional: override the default Gemini model.
# GEMINI_MODEL=gemini-3.5-flash

# Optional Cloud Run/local app URL.
# APP_URL="http://localhost:3000"
